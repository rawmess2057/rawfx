generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trade {
  id                   String  @id @default(cuid())
  userId               String
  includeInAnalysis    Boolean @default(true)
  symbol               String
  date                 String
  time                 String
  stopLoss             Float
  rrSecured            Float
  durationCandles      Int?
  maxRR                Float?
  notes                String  @default("")
  news                 String  @default("")
  newsNotes            String  @default("")
  models               String  @default("")
  extra                String  @default("")
  criteria1            Boolean @default(false)
  criteria2            Boolean @default(false)
  criteria3            Boolean @default(false)
  criteria4            Boolean @default(false)
  criteria5            Boolean @default(false)
  metOverallPlan       Boolean @default(false)
  criteriaNotes        String  @default("")
  contextScreenshot    String  @default("")
  validationScreenshot String  @default("")
  entryScreenshot      String  @default("")
  finalScreenshot      String  @default("")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
